ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...
WORKSPACE_PATH=../workspace
PORT=3001
# Cl\u00e9 API locale (optionnelle) — si d\u00e9finie, toutes les requ\u00eates doivent l'envoyer
# dans l'en-t\u00eate X-API-Key ou en query param ?api_key=
# G\u00e9n\u00e9rer avec : node -e "console.log(require('crypto').randomUUID())"
LOCAL_API_KEY=

# ── Stripe (paiements) ────────────────────────────────────────────────────────
# Dashboard Stripe > Développeurs > Clés API
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Dashboard Stripe > Développeurs > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Peut être un price_xxx (ID prix) OU un prod_xxx (ID produit — prix actif récupéré auto)
# Dashboard Stripe > Produits > ComptaOS Pro (paiement unique, 39€)
STRIPE_PRICE_PRO=prod_...
# Dashboard Stripe > Produits > ComptaOS Pro+ (abonnement mensuel, 9€)
STRIPE_PRICE_PROPLUS=prod_...

# ── GoCardless Bank Account Data (PSD2) ───────────────────────────────────────
# Créez un compte sur https://bankaccountdata.gocardless.com
# 50 connexions/mois gratuites, puis ~0.40€/connexion/mois
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
